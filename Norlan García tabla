<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=yes">
<title>📊 1 o 2 Pickeros - Productividad</title>
<style>
* {
    box-sizing: border-box;
    -webkit-tap-highlight-color: transparent;
}
body{
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    background:#1e2a3a;
    padding:10px;
    margin:0;
    color:white;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
}
.container{
    background:white;
    color:black;
    padding:15px;
    border-radius:25px;
    max-width:100%;
    width:100%;
    box-shadow: 0 10px 30px rgba(0,0,0,0.3);
}
h2{
    color:#1e3c72;
    font-size: 1.3rem;
    margin:5px 0 15px 0;
    text-align:center;
}
.selector-pickeros {
    background: #ffc107;
    padding: 10px;
    border-radius: 40px;
    margin-bottom: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 20px;
    font-weight: bold;
}
.selector-pickeros button {
    padding: 8px 20px;
    border-radius: 30px;
    border: none;
    font-weight: bold;
    background: white;
    cursor: pointer;
    font-size: 1rem;
}
.selector-pickeros button.activo {
    background: #1e3c72;
    color: white;
}
.fecha-bar {
    background: #ffc107;
    padding: 8px 15px;
    border-radius: 40px;
    margin-bottom: 15px;
    font-weight: bold;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 10px;
}
.fecha-bar input, .fecha-bar button {
    padding: 8px 15px;
    border-radius: 30px;
    border: none;
    font-weight: bold;
    background: white;
    cursor: pointer;
    font-size: 0.9rem;
}
.input-group{
    background:#e9f0fc;
    padding:15px;
    border-radius:20px;
    margin-bottom:15px;
    display:grid;
    grid-template-columns:repeat(2,1fr);
    gap:10px;
}
.input-group div{
    display:flex;
    flex-direction:column;
}
.input-group label{
    font-weight:bold;
    margin-bottom:3px;
    font-size:0.75rem;
    color:#2c3e50;
}
.input-group input, .input-group select{
    padding:8px 5px;
    border-radius:25px;
    border:2px solid #3498db;
    text-align:center;
    font-weight:bold;
    font-size: 0.9rem;
    background: white;
    width:100%;
}
.pickero-titulo{
    background:#2c3e50;
    color:white;
    padding:8px;
    border-radius:15px;
    margin:15px 0 5px 0;
    font-weight:bold;
}
.table-wrapper {
    overflow-x: auto;
    margin: 0 -5px;
    padding: 0 5px;
    border-radius: 15px;
    -webkit-overflow-scrolling: touch;
}
table {
    width: 100%;
    border-collapse: collapse;
    background: #f8fafc;
    border-radius: 15px;
    min-width: 650px;
}
th {
    background: #2c3e50;
    color: white;
    padding: 10px 5px;
    font-size: 0.75rem;
}
td {
    padding: 8px 3px;
    border-bottom: 1px solid #ccc;
    text-align: center;
    font-size: 0.75rem;
}
td input[type=number] {
    width: 50px;
    padding: 6px 2px;
    text-align: center;
    font-size: 0.8rem;
    border: 2px solid #3498db;
    border-radius: 20px;
}
.total-row {
    background: #d9e2ec;
    font-weight: bold;
}
.verde {
    background: #d4edda;
    color: #155724;
    font-weight: bold;
    padding: 4px 6px;
    border-radius: 20px;
    display: inline-block;
    min-width: 40px;
}
.rojo {
    background: #f8d7da;
    color: #721c24;
    font-weight: bold;
    padding: 4px 6px;
    border-radius: 20px;
    display: inline-block;
    min-width: 40px;
}
button {
    padding: 15px 30px;
    background: #ffc107;
    border: none;
    border-radius: 40px;
    font-weight: bold;
    cursor: pointer;
    margin: 15px auto;
    font-size: 1.2rem;
    width: calc(100% - 30px);
    max-width: 300px;
    display: block;
    box-shadow: 0 4px 8px rgba(0,0,0,0.2);
    transition: transform 0.1s;
}
button:active {
    transform: scale(0.98);
}
.result {
    background: #eef2f6;
    padding: 15px;
    border-radius: 20px;
    margin-top: 15px;
    font-size: 0.95rem;
    text-align: left;
}
.result p {
    margin: 10px 0;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 8px;
}
.result span {
    font-weight: bold;
    color: #1e3c72;
    background: #ffc107;
    padding: 5px 15px;
    border-radius: 30px;
    display: inline-block;
    margin: 2px;
    font-size: 0.85rem;
}
.result-individual {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-top: 10px;
}
.result-individual div {
    background: white;
    padding: 10px;
    border-radius: 15px;
    box-shadow: 0 2px 5px rgba(0,0,0,0.1);
}
.botones-historial {
    display: flex;
    gap: 10px;
    justify-content: center;
    margin: 10px 0;
    flex-wrap: wrap;
}
.botones-historial button {
    padding: 10px 20px;
    font-size: 0.9rem;
    margin: 0;
    width: auto;
    max-width: none;
}
</style>
</head>
<body>
<div class="container">
<h2>📊 1 O 2 PICKEROS - PRODUCTIVIDAD</h2>

<!-- Selector de cantidad de pickeros -->
<div class="selector-pickeros">
    <button id="btn1Pickero" class="activo" onclick="setPickeros(1)">👤 1 Pickero</button>
    <button id="btn2Pickeros" onclick="setPickeros(2)">👥 2 Pickeros</button>
</div>

<div class="fecha-bar">
    <span>📆 Fecha:</span>
    <input type="date" id="selectorFecha" value="">
    <button onclick="cargarDia()">📂 Cargar</button>
    <button onclick="guardarDia()">💾 Guardar</button>
    <button onclick="reiniciarDia()">🆕 Nuevo Día</button>
</div>

<div class="input-group">
    <div><label>📦 Tareas totales:</label><input type="number" id="tareas" value="263"></div>
    <div><label>🍽️ Desayuno (horas):</label><input type="number" id="desayuno" value="0.5" step="0.5"></div>
    <div><label>⏰ Hora pedida:</label>
        <select id="horaPedida">
            <option value="10">10am</option><option value="11">11am</option>
            <option value="12">12pm</option><option value="13">1pm</option>
            <option value="14" selected>2pm</option>
        </select>
    </div>
    <div><label>⏱️ Hora real:</label>
        <select id="horaReal">
            <option value="8">8am</option><option value="9">9am</option><option value="10">10am</option>
            <option value="11" selected>11am</option><option value="12">12pm</option>
            <option value="13">1pm</option><option value="14">2pm</option>
        </select>
    </div>
    <div><label>⏱️ Minutos reales:</label>
        <select id="minutosReal">
            <option value="0">00</option><option value="15">15</option>
            <option value="30" selected>30</option><option value="45">45</option>
        </select>
    </div>
</div>

<!-- Metas por corte -->
<div class="pickero-titulo">🎯 METAS DEL PASILLO (por corte)</div>
<div class="table-wrapper">
<table>
    <tr><th>Corte</th><th>Horario</th><th>Meta</th></tr>
    <tr><td>1</td><td>6-8</td><td><input type="number" id="m1" value="72"></td></tr>
    <tr><td>2</td><td>8-10</td><td><input type="number" id="m2" value="64"></td></tr>
    <tr><td>3</td><td>10-12</td><td><input type="number" id="m3" value="72"></td></tr>
    <tr><td>4</td><td>12-14</td><td><input type="number" id="m4" value="55"></td></tr>
    <tr class="total-row"><td colspan="2"><strong>META TOTAL</strong></td><td id="metaTotal">263</td></tr>
</table>
</div>

<!-- Pickero 1 (siempre visible) -->
<div class="pickero-titulo">👤 PICKERO #1</div>
<div class="table-wrapper">
<table>
    <tr><th>Corte</th><th>Horario</th><th>Real</th><th>Acum</th><th>Dif</th><th>%</th></tr>
    <tr><td>1</td><td>6-8</td><td><input type="number" id="p1r1" value="0"></td><td id="p1ra1">0</td><td id="p1d1" class="rojo">0</td><td id="p1p1">0%</td></tr>
    <tr><td>2</td><td>8-10</td><td><input type="number" id="p1r2" value="0"></td><td id="p1ra2">0</td><td id="p1d2" class="rojo">0</td><td id="p1p2">0%</td></tr>
    <tr><td>3</td><td>10-12</td><td><input type="number" id="p1r3" value="0"></td><td id="p1ra3">0</td><td id="p1d3" class="rojo">0</td><td id="p1p3">0%</td></tr>
    <tr><td>4</td><td>12-14</td><td><input type="number" id="p1r4" value="0"></td><td id="p1ra4">0</td><td id="p1d4" class="rojo">0</td><td id="p1p4">0%</td></tr>
    <tr class="total-row"><td colspan="2"><strong>TOTAL</strong></td><td id="p1total">0</td><td id="p1raF">0</td><td id="p1dF" class="rojo">0</td><td id="p1pF">0%</td></tr>
</table>
</div>

<!-- Pickero 2 (oculto por defecto) -->
<div id="pickero2Container" style="display: none;">
    <div class="pickero-titulo">👤 PICKERO #2</div>
    <div class="table-wrapper">
    <table>
        <tr><th>Corte</th><th>Horario</th><th>Real</th><th>Acum</th><th>Dif</th><th>%</th></tr>
        <tr><td>1</td><td>6-8</td><td><input type="number" id="p2r1" value="0"></td><td id="p2ra1">0</td><td id="p2d1" class="rojo">0</td><td id="p2p1">0%</td></tr>
        <tr><td>2</td><td>8-10</td><td><input type="number" id="p2r2" value="0"></td><td id="p2ra2">0</td><td id="p2d2" class="rojo">0</td><td id="p2p2">0%</td></tr>
        <tr><td>3</td><td>10-12</td><td><input type="number" id="p2r3" value="0"></td><td id="p2ra3">0</td><td id="p2d3" class="rojo">0</td><td id="p2p3">0%</td></tr>
        <tr><td>4</td><td>12-14</td><td><input type="number" id="p2r4" value="0"></td><td id="p2ra4">0</td><td id="p2d4" class="rojo">0</td><td id="p2p4">0%</td></tr>
        <tr class="total-row"><td colspan="2"><strong>TOTAL</strong></td><td id="p2total">0</td><td id="p2raF">0</td><td id="p2dF" class="rojo">0</td><td id="p2pF">0%</td></tr>
    </table>
    </div>
</div>

<button onclick="calcularTodo()">📊 CALCULAR PRODUCTIVIDAD</button>

<div class="result" id="resultado"></div>

</div>

<script>
let cantidadPickeros = 1;

function setPickeros(cant) {
    cantidadPickeros = cant;
    
    // Actualizar botones
    document.getElementById("btn1Pickero").className = cant === 1 ? "activo" : "";
    document.getElementById("btn2Pickeros").className = cant === 2 ? "activo" : "";
    
    // Mostrar/ocultar pickero 2
    document.getElementById("pickero2Container").style.display = cant === 2 ? "block" : "none";
    
    calcularTodo();
}

function calcularProductividad(reales) {
    let tareas = parseFloat(document.getElementById("tareas").value) || 0;
    let horaPedida = parseInt(document.getElementById("horaPedida").value);
    let horaReal = parseInt(document.getElementById("horaReal").value);
    let minutosReal = parseInt(document.getElementById("minutosReal").value) || 0;
    let desayuno = parseFloat(document.getElementById("desayuno").value) || 0;
    let almuerzo = 0.5;
    
    // Horas base
    let horasBase = horaPedida === 14 ? horaPedida - 6 - desayuno - almuerzo : horaPedida - 6 - desayuno;
    horasBase = Math.max(0, horasBase);
    
    // Horas reales
    let horasReales = horaReal >= 12 
        ? horaReal - 6 - desayuno - almuerzo + minutosReal/60
        : horaReal - 6 - desayuno + minutosReal/60;
    horasReales = Math.max(0, horasReales);
    
    // Ritmo base individual
    let metaPorPersona = cantidadPickeros === 1 ? tareas : tareas / 2;
    let ritmoBase = horasBase > 0 ? metaPorPersona / horasBase : 0;
    
    // Ritmo real
    let ritmoReal = horasReales > 0 ? reales / horasReales : 0;
    
    // Productividad
    let productividad = ritmoBase > 0 ? (ritmoReal / ritmoBase) * 100 : 0;
    
    return {
        reales,
        horasReales,
        ritmoReal,
        productividad
    };
}

function calcularTodo() {
    // Metas
    let m1 = +document.getElementById("m1").value || 0;
    let m2 = +document.getElementById("m2").value || 0;
    let m3 = +document.getElementById("m3").value || 0;
    let m4 = +document.getElementById("m4").value || 0;
    let metas = [m1, m2, m3, m4];
    let metaTotal = metas.reduce((a,b)=>a+b,0);
    document.getElementById("metaTotal").innerText = metaTotal;
    
    // Pickero 1
    let p1r1 = +document.getElementById("p1r1").value || 0;
    let p1r2 = +document.getElementById("p1r2").value || 0;
    let p1r3 = +document.getElementById("p1r3").value || 0;
    let p1r4 = +document.getElementById("p1r4").value || 0;
    let p1Reales = [p1r1, p1r2, p1r3, p1r4];
    let p1Total = p1Reales.reduce((a,b)=>a+b,0);
    
    // Acumulados pickero 1
    let p1Acum = 0;
    for(let i=0; i<4; i++) {
        p1Acum += p1Reales[i];
        let metaAcum = metas.slice(0,i+1).reduce((a,b)=>a+b,0);
        let dif = p1Acum - metaAcum;
        let prod = metaAcum > 0 ? ((p1Acum / metaAcum) * 100).toFixed(1) + "%" : "0%";
        
        document.getElementById(`p1ra${i+1}`).innerText = p1Acum;
        document.getElementById(`p1d${i+1}`).innerText = (dif >= 0 ? '+' : '') + dif;
        document.getElementById(`p1d${i+1}`).className = dif >= 0 ? 'verde' : 'rojo';
        document.getElementById(`p1p${i+1}`).innerText = prod;
    }
    document.getElementById("p1total").innerText = p1Total;
    document.getElementById("p1raF").innerText = p1Total;
    let difFinal1 = p1Total - metaTotal;
    document.getElementById("p1dF").innerText = (difFinal1 >= 0 ? '+' : '') + difFinal1;
    document.getElementById("p1dF").className = difFinal1 >= 0 ? 'verde' : 'rojo';
    document.getElementById("p1pF").innerText = metaTotal > 0 ? ((p1Total / metaTotal) * 100).toFixed(1) + "%" : "0%";
    
    let res1 = calcularProductividad(p1Total);
    
    // Si hay 2 pickeros
    if(cantidadPickeros === 2) {
        let p2r1 = +document.getElementById("p2r1").value || 0;
        let p2r2 = +document.getElementById("p2r2").value || 0;
        let p2r3 = +document.getElementById("p2r3").value || 0;
        let p2r4 = +document.getElementById("p2r4").value || 0;
        let p2Reales = [p2r1, p2r2, p2r3, p2r4];
        let p2Total = p2Reales.reduce((a,b)=>a+b,0);
        
        // Acumulados pickero 2
        let p2Acum = 0;
        for(let i=0; i<4; i++) {
            p2Acum += p2Reales[i];
            let metaAcum = metas.slice(0,i+1).reduce((a,b)=>a+b,0);
            let dif = p2Acum - metaAcum;
            let prod = metaAcum > 0 ? ((p2Acum / metaAcum) * 100).toFixed(1) + "%" : "0%";
            
            document.getElementById(`p2ra${i+1}`).innerText = p2Acum;
            document.getElementById(`p2d${i+1}`).innerText = (dif >= 0 ? '+' : '') + dif;
            document.getElementById(`p2d${i+1}`).className = dif >= 0 ? 'verde' : 'rojo';
            document.getElementById(`p2p${i+1}`).innerText = prod;
        }
        document.getElementById("p2total").innerText = p2Total;
        document.getElementById("p2raF").innerText = p2Total;
        let difFinal2 = p2Total - metaTotal;
        document.getElementById("p2dF").innerText = (difFinal2 >= 0 ? '+' : '') + difFinal2;
        document.getElementById("p2dF").className = difFinal2 >= 0 ? 'verde' : 'rojo';
        document.getElementById("p2pF").innerText = metaTotal > 0 ? ((p2Total / metaTotal) * 100).toFixed(1) + "%" : "0%";
        
        let res2 = calcularProductividad(p2Total);
        
        function getRango(prod) {
            if(prod >= 130) return {rango:"130% o más", incentivo:3150};
            if(prod >= 120) return {rango:"120-129.99%", incentivo:3000};
            if(prod >= 110) return {rango:"110-119.99%", incentivo:2850};
            if(prod >= 100) return {rango:"100-109.99%", incentivo:2700};
            if(prod >= 90) return {rango:"90-99.99%", incentivo:2400};
            if(prod >= 80) return {rango:"80-89.99%", incentivo:2100};
            return {rango:"<80%", incentivo:0};
        }
        
        let r1 = getRango(res1.productividad);
        let r2 = getRango(res2.productividad);
        
        document.getElementById("resultado").innerHTML = `
            <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
                <div style="background:white;padding:10px;border-radius:15px;">
                    <strong>👤 PICKERO #1</strong>
                    <p>✅ Real: ${p1Total} tareas</p>
                    <p>⏱️ Horas: ${res1.horasReales.toFixed(2)}h</p>
                    <p>⚡ Ritmo: ${res1.ritmoReal.toFixed(2)} t/h</p>
                    <p>📈 Productividad: <span>${res1.productividad.toFixed(1)}%</span></p>
                    <p>🎯 Rango: ${r1.rango}</p>
                    <p>💰 Incentivo: C$${r1.incentivo}</p>
                </div>
                <div style="background:white;padding:10px;border-radius:15px;">
                    <strong>👤 PICKERO #2</strong>
                    <p>✅ Real: ${p2Total} tareas</p>
                    <p>⏱️ Horas: ${res2.horasReales.toFixed(2)}h</p>
                    <p>⚡ Ritmo: ${res2.ritmoReal.toFixed(2)} t/h</p>
                    <p>📈 Productividad: <span>${res2.productividad.toFixed(1)}%</span></p>
                    <p>🎯 Rango: ${r2.rango}</p>
                    <p>💰 Incentivo: C$${r2.incentivo}</p>
                </div>
            </div>
        `;
    } else {
        function getRango(prod) {
            if(prod >= 130) return {rango:"130% o más", incentivo:3150};
            if(prod >= 120) return {rango:"120-129.99%", incentivo:3000};
            if(prod >= 110) return {rango:"110-119.99%", incentivo:2850};
            if(prod >= 100) return {rango:"100-109.99%", incentivo:2700};
            if(prod >= 90) return {rango:"90-99.99%", incentivo:2400};
            if(prod >= 80) return {rango:"80-89.99%", incentivo:2100};
            return {rango:"<80%", incentivo:0};
        }
        
        let r1 = getRango(res1.productividad);
        
        document.getElementById("resultado").innerHTML = `
            <div style="background:white;padding:15px;border-radius:15px;">
                <strong>👤 PICKERO #1</strong>
                <p>✅ Real: ${p1Total} tareas</p>
                <p>⏱️ Horas: ${res1.horasReales.toFixed(2)}h</p>
                <p>⚡ Ritmo: ${res1.ritmoReal.toFixed(2)} t/h</p>
                <p>📈 Productividad: <span>${res1.productividad.toFixed(1)}%</span></p>
                <p>🎯 Rango: ${r1.rango}</p>
                <p>💰 Incentivo: C$${r1.incentivo}</p>
            </div>
        `;
    }
}

function guardarDia() { alert("Función guardar (puedes implementarla después)"); }
function cargarDia() { alert("Función cargar (puedes implementarla después)"); }
function reiniciarDia() {
    if(confirm("¿Reiniciar todos los valores?")) {
        document.getElementById("p1r1").value = "0";
        document.getElementById("p1r2").value = "0";
        document.getElementById("p1r3").value = "0";
        document.getElementById("p1r4").value = "0";
        document.getElementById("p2r1").value = "0";
        document.getElementById("p2r2").value = "0";
        document.getElementById("p2r3").value = "0";
        document.getElementById("p2r4").value = "0";
        calcularTodo();
    }
}

// Inicializar
setPickeros(1);
</script>

</body>
</html>
